{
  "name": "claude-usage-bar",
  "displayName": "Claude Usage Bar",
  "description": "Shows your Claude Code rate limit usage in the VS Code status bar via statusLine integration — session %, reset countdown, and color alerts. Zero API calls.",
  "version": "0.3.3",
  "publisher": "HarshAgarwal1012",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harsh1210/claude-usage-bar"
  },
  "homepage": "https://github.com/Harsh1210/claude-usage-bar",
  "bugs": {
    "url": "https://github.com/Harsh1210/claude-usage-bar/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["claude", "anthropic", "rate limit", "usage", "status bar", "claude code", "ai"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Usage Bar",
      "properties": {
        "claudeUsageBar.displayMode": {
          "type": "string",
          "enum": ["session", "weekly", "both"],
          "default": "session",
          "enumDescriptions": [
            "Show session (5-hour) rate limit",
            "Show weekly (7-day) rate limit",
            "Show both session and weekly limits"
          ],
          "description": "Which rate limit to display in the status bar"
        }
      }
    },
    "commands": [
      {
        "command": "claudeUsageBar.refresh",
        "title": "Claude Usage: Refresh"
      },
      {
        "command": "claudeUsageBar.showDetails",
        "title": "Claude Usage: Show Session Details"
      },
      {
        "command": "claudeUsageBar.refreshRateLimit",
        "title": "Claude Usage: Refresh Rate Limit"
      },
      {
        "command": "claudeUsageBar.switchDisplayMode",
        "title": "Claude Usage: Switch Display Mode (Session / Weekly / Both)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
